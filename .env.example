# Copy to `.env` and fill in. Never commit `.env`.

# OpenAI — required for `--mode run` and for storage layout image generation (`analyze` / `run`)
OPENAI_API_KEY=

# Etherscan API V2 — OPTIONAL fallback only (Sourcify is always tried first).
# Used only when Sourcify returns 404 / no sources. https://etherscan.io/apis — ai/ETHERSCAN_INDEX.md
ETHERSCAN_API_KEY=

# Optional: override default https://api.etherscan.io/v2/api
# ETHERSCAN_API_URL=https://api.etherscan.io/v2/api

# Optional: seconds (default 15) for HTTP requests to Sourcify and Etherscan
HTTP_TIMEOUT=15

# Optional: write raw fetched JSON when running analyze/run
# DEBUG_MODE=1
# DEBUG_JSON=./debug_contract.json
